# ============================================================
#  .env.local — 本地开发覆盖(覆盖 .env 里的同名值)
#  用途:在本地跑 bridge 连本地 relay,不影响 .env 里的生产配置。
#  本文件不要提交进 git。
# ============================================================

# ---- 连本地 relay(backend/dev_server.py 默认端口)--------------
RELAY_URL=http://127.0.0.1:3011
RELAY_SECRET=dev-local-secret

# ---- 日志级别: debug / info / warn / error --------------------
LOG_LEVEL=debug
