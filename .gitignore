# ── secrets & private state — NEVER commit ──────────────────────────────
# Filled env files (the templates *.env.example are the only ones tracked)
relay.env
.env
**/.env
!**/.env.example
# VAPID / TLS private keys
*.pem
*.key
# Runtime data: the conversation DB and uploaded attachments are private
relay.db
relay.db-*
uploads/
inbox/
last_in_id
# Runtime state (written by the app, not source code)
backend/brain_target
backend/model_config.json
backend/relay.env.local
# Hardcoded-secret bat files (use .ps1 scripts with env files instead)
start_relay.bat

# ── runtime logs & test artifacts ───────────────────────────────────────
*.log
bridge_err.log
bridge_out.log
sse_test.txt
logs/
memory_imports/

# ── build / deps ────────────────────────────────────────────────────────
node_modules/
bun.lock
bun.lockb
__pycache__/
*.pyc
venv/
.venv/

# ── editor / OS noise ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.bak
*.bak-*
.idea/
.vscode/
